# Claude Hotmail Connector — environment template.
# Copy to `.env` and fill in. NEVER commit the real .env (it is git-ignored).

# ── Bring your own registration (optional) ───────────────────────────────────
# Client id of a Microsoft Entra app registration (a PUBLIC / native client).
# LEAVE BLANK to use the bundled shared client id. Set this only to bring your
# own registration. No client secret is used — public clients use PKCE.
MICROSOFT_CLIENT_ID=

# ── Optional (sensible defaults shown) ───────────────────────────────────────
# Tenant segment. `common` enables BOTH personal Microsoft accounts
# (hotmail/outlook/live) and work/school accounts. Leave as `common`.
MICROSOFT_TENANT=common

# Default IANA time zone for calendar reads and writes.
DEFAULT_TIMEZONE=Australia/Brisbane

# Space- or comma-separated delegated Graph scopes. Leave unset to use the
# least-privilege default:
#   openid profile email offline_access User.Read Mail.Read Calendars.ReadWrite
# MICROSOFT_SCOPES=

# Log verbosity: debug | info | warn | error. Logs go to stderr only.
LOG_LEVEL=info

# Override the directory for the encrypted token cache. Defaults to
# %LOCALAPPDATA%\claude-hotmail-connector on Windows, else ~/.claude-hotmail-connector.
# CLAUDE_HOTMAIL_CACHE_DIR=
